---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

import Testimonials from '@/components/sections/testimonials';
import Hero from '@/components/sections/hero';
import { Logos17 } from '@/components/logos17';
import Features from '@/components/sections/features';
import Adaptive from '@/components/sections/adaptive';
import Surfaces from '@/components/sections/surfaces';
import Optimize from '@/components/sections/optimize';
import Accelerate from '@/components/sections/accelerate';
import Pricing from '@/components/sections/pricing';
import Faq from '@/components/sections/faq';
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Hero client:load />
  <Logos17 client:only='react' />
  <Features client:only='react' />
  <Adaptive />
  <Surfaces />
  <Optimize client:only='react'/>
  <Accelerate />
  <Testimonials />
  <Pricing />
  <Faq client:only='react'/>
</DefaultLayout>
